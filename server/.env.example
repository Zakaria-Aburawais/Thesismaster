# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Anthropic API key — the only place it exists; the client never sees it.
ANTHROPIC_API_KEY=

# Long random string (e.g. `openssl rand -hex 32`). Rotating it signs everyone out.
JWT_SECRET=

# Paddle Billing webhook secret (dashboard → Notifications → your webhook → secret).
# Leave empty until payments launch: the webhook endpoint fails closed without it.
PADDLE_WEBHOOK_SECRET=

# PORT=3000
